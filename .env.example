# =============================================================================
#  DevScore — environment variables
#  Copy this to .env.local for local dev, or set in your hosting provider for prod.
# =============================================================================

# Which storage backend to use. Default = indexeddb (browser-only, zero-config).
# Set to "supabase" for production Postgres.
VITE_BACKEND=supabase

# Required only when VITE_BACKEND=supabase
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
 VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
